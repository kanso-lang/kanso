# an expensive value bound, then passed to an arm that ignores it. today
# the strict engines compute it anyway; when the lazy fragment lands, the
# .mem golden pins that the skipped computation evaluates zero times.
fn burn 0 acc
  acc

fn burn n acc
  burn (n - 1) (acc + n)

fn pick false _
  0

fn pick true chosen
  chosen

pub play =
  expensive = burn 2000 0
  print "picked: {pick false expensive}"
