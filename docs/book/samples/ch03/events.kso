type joined
  who:string

type left
  who:string

type renamed
  after:string
  before:string

pub play =
  print (render (joined "clay"))
  >> print (render (renamed "kanso" "kai"))
  >> print (render (left "mugi"))

fn render (joined who)
  "{who} joined"

fn render (left who)
  "{who} left"

fn render (renamed after before)
  "{before} is now {after}"
