import "std/list"

fn describe none
  "no ninth price"

fn describe x
  "ninth price: {x}"

pub play =
  prices = [30 10 20]
  doubled = list/to_list (list/map prices (x -> x * 2))
  ninth = prices[9]
  print "sorted: {list/sort prices}"
    >> print "doubled: {doubled}"
    >> print (describe ninth)
