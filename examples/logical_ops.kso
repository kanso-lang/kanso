# && and || are spelling for the deferred if family: `a && b` is
# `if a b false`, `a || b` is `if a true b`. the right side defers
# exactly as an if branch does, so short-circuit is the semantics, not
# a special case — the untaken side never runs.
fn brewable? temp
  (60 < temp) && (temp < 85)

pub play =
  print "{brewable? 72} {brewable? 95}"
  >> print "{(2 < 1) || (1 < 2)}"
  >> print "{(2 < 1) && ((1 / 0) < 9)}"
