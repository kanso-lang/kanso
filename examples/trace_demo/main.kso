fn banner line
  "== {line} =="

fn check text
  version = major_of text
  summary = describe version
  print (banner summary)

fn chosen argv
  if (length argv == 0) "examples/trace_demo/VERSION" (at argv 1)

fn describe v
  "major version {v} detected"

main = args . start

fn start argv
  read_file (chosen argv) . check
